generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AssetHistory {
  id            Int                         @id @default(autoincrement())
  table_name    String                      @db.VarChar(50)
  asset_id      Int
  asset_code    String?                     @db.VarChar(20)
  action        assethistory_action
  from_employee String?                     @db.VarChar(100)
  to_employee   String?                     @db.VarChar(100)
  from_location String?                     @db.VarChar(100)
  to_location   String?                     @db.VarChar(100)
  old_condition assethistory_old_condition?
  new_condition assethistory_new_condition?
  changed_by    String?                     @db.VarChar(100)
  notes         String?                     @db.Text
  event_at      DateTime                    @default(now())
}

model Camera {
  id            Int              @id @default(autoincrement())
  asset_code    String?          @unique(map: "Camera_asset_code_key") @db.VarChar(20)
  pic           String?          @db.VarChar(100)
  brand         String?          @db.VarChar(50)
  model         String?          @db.VarChar(100)
  accessories   Json?
  location      String?          @db.VarChar(100)
  handover_date DateTime?
  return_date   DateTime?
  purchase_date DateTime?
  condition     camera_condition @default(Baik)
  notes         String?          @db.Text
  created_at    DateTime         @default(now())
  updated_at    DateTime
}

model Cctv {
  id             Int            @id @default(autoincrement())
  asset_code     String?        @unique(map: "Cctv_asset_code_key") @db.VarChar(20)
  brand          String?        @db.VarChar(50)
  model          String?        @db.VarChar(50)
  location       String?        @db.VarChar(100)
  position_label String?        @db.VarChar(100)
  ip_address     String?        @db.VarChar(45)
  mac_address    String?        @db.VarChar(17)
  install_date   DateTime?
  condition      cctv_condition @default(Baik)
  notes          String?        @db.Text
  created_at     DateTime       @default(now())
  updated_at     DateTime
}

model Dashcam {
  id              Int               @id @default(autoincrement())
  asset_code      String?           @unique(map: "Dashcam_asset_code_key") @db.VarChar(20)
  vehicle_name    String            @db.VarChar(100)
  plate_number    String?           @db.VarChar(20)
  location        String?           @db.VarChar(100)
  project         String?           @db.VarChar(100)
  install_status  String            @default("Belum Terpasang") @db.VarChar(50)
  install_date    DateTime?
  notes           String?           @db.Text
  azdome_email    String?           @db.VarChar(150)
  azdome_password String?           @db.VarChar(255)
  gmail           String?           @db.VarChar(150)
  gmail_password  String?           @db.VarChar(255)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
}

model Ht {
  id              Int          @id @default(autoincrement())
  asset_code      String?      @unique(map: "Ht_asset_code_key") @db.VarChar(20)
  pic_name        String?      @db.VarChar(100)
  department      String?      @db.VarChar(100)
  division        String?      @db.VarChar(100)
  job_level       String?      @db.VarChar(100)
  branch          String?      @db.VarChar(100)
  handover_date   DateTime?
  return_date     DateTime?
  brand           String?      @db.VarChar(50)
  type            String?      @db.VarChar(100)
  accessories     String?      @db.VarChar(255)
  condition       ht_condition @default(Baik)
  notes           String?      @db.Text
  form_path       String?      @db.VarChar(255)
  it_handover     String?      @db.VarChar(100)
  it_receiver     String?      @db.VarChar(100)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
}

model Laptop {
  id              Int              @id @default(autoincrement())
  asset_code      String?          @unique(map: "Laptop_asset_code_key") @db.VarChar(20)
  pic             String?          @db.VarChar(100)
  department      String?          @db.VarChar(100)
  division        String?          @db.VarChar(100)
  job_level       String?          @db.VarChar(50)
  branch          String?          @db.VarChar(100)
  brand           String?          @db.VarChar(50)
  model           String?          @db.VarChar(100)
  ram             String?          @db.VarChar(50)
  storage         String?          @db.VarChar(50)
  processor       String?          @db.VarChar(100)
  screen_size     String?          @db.VarChar(50)
  mac_address     String?          @db.VarChar(17)
  handover_date   DateTime?
  return_date     DateTime?
  condition       laptop_condition @default(Baik)
  attachment_name String?          @db.VarChar(255)
  attachment_path String?          @db.VarChar(500)
  notes           String?          @db.Text
  it_handover     String?          @db.VarChar(100)
  it_receiver     String?          @db.VarChar(100)
  created_at      DateTime         @default(now())
  updated_at      DateTime
}

enum generalinventory_condition {
  Baik
  Rusak
  Hilang
}

model GeneralInventory {
  id              Int                       @id @default(autoincrement())
  asset_code      String?                   @unique(map: "GeneralInventory_asset_code_key") @db.VarChar(20)
  pic_name        String                    @db.VarChar(100)
  department      String?                   @db.VarChar(100)
  division        String?                   @db.VarChar(100)
  job_level       String?                   @db.VarChar(100)
  branch          String?                   @db.VarChar(100)
  asset_type      String?                   @db.VarChar(100)
  brand           String?                   @db.VarChar(100)
  quantity        Int                       @default(1)
  handover_date   DateTime?
  return_date     DateTime?
  condition       generalinventory_condition @default(Baik)
  notes           String?                   @db.Text
  handover_form   String?                   @db.VarChar(255)
  return_form     String?                   @db.VarChar(255)
  it_handover     String?                   @db.VarChar(100)
  it_receiver     String?                   @db.VarChar(100)
  created_at      DateTime                  @default(now())
  updated_at      DateTime                  @updatedAt
}

model NetworkDevice {
  id            Int                     @id @default(autoincrement())
  asset_code    String?                 @unique(map: "NetworkDevice_asset_code_key") @db.VarChar(20)
  name          String                  @db.VarChar(100)
  device_type   String?                 @db.VarChar(50)
  mac_address   String?                 @db.VarChar(17)
  location      String?                 @db.VarChar(100)
  purchase_date DateTime?
  notes         String?                 @db.Text
  created_at    DateTime                @default(now())
  updated_at    DateTime                @updatedAt
}

model Printer {
  id            Int                 @id @default(autoincrement())
  asset_code    String?             @unique(map: "Printer_asset_code_key") @db.VarChar(20)
  brand         String?             @db.VarChar(50)
  model         String?             @db.VarChar(100)
  location      String?             @db.VarChar(100)
  condition     printer_condition   @default(Baik)
  ink_type      String?             @db.VarChar(50)
  mac_address   String?             @db.VarChar(17)
  ip_address    String?             @db.VarChar(45)
  connection    printer_connection?
  purchase_date DateTime?
  notes         String?             @db.Text
  created_at    DateTime            @default(now())
  updated_at    DateTime
}

model Starlink {
  id                Int                @id @default(autoincrement())
  asset_code        String?            @unique(map: "Starlink_asset_code_key") @db.VarChar(20)
  location          String?            @db.VarChar(100)
  serial_number     String?            @unique(map: "Starlink_serial_number_key") @db.VarChar(50)
  account_email     String?            @db.VarChar(150)
  install_date      DateTime?
  notes             String?            @db.Text
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
}

model Tablet {
  id              Int              @id @default(autoincrement())
  asset_code      String?          @unique(map: "Tablet_asset_code_key") @db.VarChar(20)
  pic_name        String?          @db.VarChar(100)
  department      String?          @db.VarChar(100)
  division        String?          @db.VarChar(100)
  job_level       String?          @db.VarChar(100)
  branch          String?          @db.VarChar(100)
  handover_date   DateTime?
  return_date     DateTime?
  asset_type      String?          @db.VarChar(100)
  brand           String?          @db.VarChar(50)
  type            String?          @db.VarChar(100)
  ram             String?          @db.VarChar(50)
  storage         String?          @db.VarChar(50)
  condition       tablet_condition @default(Baik)
  notes           String?          @db.Text
  form_path       String?          @db.VarChar(255)
  it_handover     String?          @db.VarChar(100)
  it_receiver     String?          @db.VarChar(100)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
}

enum assethistory_action {
  Dibuat
  Diperbarui
  Dipindah_Lokasi
  Diserahkan
  Dikembalikan
  Kondisi_Berubah
  Dihapus
}

enum printer_condition {
  Baru
  Baik
  Perlu_Servis
  Rusak
  Hilang
  Tidak_Aktif
}

enum starlink_condition {
